  (text "RFMP Pager Carrier HAT v1.0\n\nOPi Zero 2W 40-pin Header -> JST-XH Connectors\n\nJ2 DISPLAY (8-pin JST-XH):\n  1=3V3  2=GND  3=SCLK  4=MOSI  5=CE0  6=DC  7=RST  8=BLK\n  From OPi pins: 1, 6, 23, 19, 24, 18, 12, 17\n\nJ3 KEYBOARD (5-pin JST-XH):\n  1=3V3  2=GND  3=SDA  4=SCL  5=INT\n  From OPi pins: 1, 9, 3, 5, 7\n\nD1+R1: Status LED\n  GPIO5 (Pin 29) -> R1 220ohm -> D1 LED -> GND (Pin 30)\n\nC1: 100nF decoupling across 3V3/GND"
    (at 25.4 25.4 0)
    (effects
      (font (size 1.27 1.27))
      (justify left)
    )
    (uuid "b0000001-0001-0001-0001-000000000001")
  )

